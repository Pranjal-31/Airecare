   "source": [
    "# Query 4 — days where ALL 3 conditions are high risk at the same time\n",
    "query4 = \"\"\"\n",
    "SELECT Season, Month, TempMax_C, Humidity_pct, AQI, PressureChange_hPa\n",
    "FROM weather_health\n",
    "WHERE Migraine = 1\n",
    "  AND Allergy = 1\n",
    "  AND JointPain = 1\n",
    "ORDER BY AQI DESC\n",
    "\"\"\"\n",
    "print('Days where all 3 conditions triggered together:')\n",
    "pd.read_sql(query4, conn)"
   ]
