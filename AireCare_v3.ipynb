    "    auc,\n",
    "    accuracy_score,\n",
    "    f1_score\n",
    ")\n",
    "\n",
    "SEED = 42  # so results are same every run\n",
    "rng  = np.random.default_rng(SEED)  # our random number generator\n",
    "\n",
    "print('✅ Imports done')"
