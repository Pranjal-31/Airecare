    "def predict_today(weather, user_conditions):\n",
    "    \"\"\"\n",
    "    weather         : dict with today's weather values\n",
    "    user_conditions : list of conditions the user has selected\n",
    "    \"\"\"\n",
    "    row = pd.DataFrame([weather])\n",
    "\n",
    "    # add the same engineered features\n",
    "    row['HeatIndex']         = (row['TempMax_C'] + 0.33*row['Humidity_pct']\n",
    "                                - 0.70*row['WindSpeed_kmh'] - 4.0)\n",
    "    row['ColdDampScore']     = ((10 - row['TempMin_C'].clip(upper=10)) *\n",
    "                                 row['Humidity_pct'] / 100).clip(lower=0)\n",
    "    row['AbsPressureChange'] = row['PressureChange_hPa'].abs()\n",
    "\n",
    "    print('🌤️  AireCare Health Alert')\n",
    "    print('─' * 35)\n",
    "\n",
    "    for condition in user_conditions:\n",
    "        res    = all_results[condition]\n",
    "        scaled = res['scaler'].transform(row[FEATURES])\n",
    "        prob   = res['models'][res['best']]['model'].predict_proba(scaled)[0, 1]\n",
    "        pct    = prob * 100\n",
    "        bar    = '█' * int(pct//5) + '░' * (20 - int(pct//5))\n",
    "        flag   = '⚠️ HIGH' if pct > 60 else ('⚡ MODERATE' if pct > 35 else '✅ LOW')\n",
    "        print(f'  {condition:<12}: {bar} {pct:.0f}% — {flag}')\n",
    "\n",
    "    print('─' * 35)\n",
    "\n",
    "\n",
    "# try a hot summer day in Delhi\n",
    "print('Hot summer day:')\n",
    "predict_today(\n",
    "    weather={\n",
    "        'TempMax_C': 41, 'TempMin_C': 27, 'TempRange_C': 14,\n",
    "        'Humidity_pct': 35, 'Pressure_hPa': 1004,\n",
    "        'PressureChange_hPa': -7, 'WindSpeed_kmh': 18,\n",
    "        'AQI': 190, 'PollenCount': 120, 'UV_Index': 11,\n",
    "        'Season_PostMonsoon': 0, 'Season_Summer': 1, 'Season_Winter': 0\n",
    "    },\n",
    "    user_conditions=['Migraine', 'Allergy', 'JointPain']\n",
    ")\n",
    "\n",
    "print()\n",
    "\n",
    "# try a cold winter morning\n",
    "print('Cold winter morning:')\n",
    "predict_today(\n",
    "    weather={\n",
    "        'TempMax_C': 16, 'TempMin_C': 7, 'TempRange_C': 9,\n",
    "        'Humidity_pct': 72, 'Pressure_hPa': 1008,\n",
    "        'PressureChange_hPa': -8, 'WindSpeed_kmh': 9,\n",
    "        'AQI': 280, 'PollenCount': 20, 'UV_Index': 4,\n",
    "        'Season_PostMonsoon': 0, 'Season_Summer': 0, 'Season_Winter': 1\n",
    "    },\n",
    "    user_conditions=['Migraine', 'Allergy', 'JointPain']\n",
    ")"
   ]
