    "rows = []\n",
    "for target in ['Migraine', 'Allergy', 'JointPain']:\n",
    "    res    = all_results[target]\n",
    "    y_test = res['y_test']\n",
    "    for name, mres in res['models'].items():\n",
    "        is_best = (name == res['best'])\n",
    "        rows.append({\n",
    "            'Condition' : target,\n",
    "            'Model'     : ('★ ' if is_best else '  ') + name,\n",
    "            'Test AUC'  : round(mres['test_auc'], 3),\n",
    "            'Accuracy'  : round(accuracy_score(y_test, mres['y_pred']), 3),\n",
    "            'F1'        : round(f1_score(y_test, mres['y_pred']), 3)\n",
    "        })\n",
    "\n",
    "summary = pd.DataFrame(rows)\n",
    "display(\n",
    "    summary.style\n",
    "    .highlight_max(subset=['Test AUC', 'Accuracy', 'F1'], color='#d4f1c0')\n",
    "    .set_caption('★ = best per condition | green = highest per metric')\n",
    ")"
   ]
  },
