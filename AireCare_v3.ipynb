    "# Query 1 — which season has the most risk days for each condition?\n",
    "query1 = \"\"\"\n",
    "SELECT Season,\n",
    "       SUM(Migraine)  AS migraine_days,\n",
    "       SUM(Allergy)   AS allergy_days,\n",
    "       SUM(JointPain) AS joint_pain_days\n",
    "FROM weather_health\n",
    "GROUP BY Season\n",
    "ORDER BY migraine_days DESC\n",
    "\"\"\"\n",
    "print('Risk days per season:')\n",
    "pd.read_sql(query1, conn)"
