     "metadata": {
      "needs_background": "light"
     },
     "output_type": "display_data"
    }
   ],
   "source": [
    "# for each season, what % of days are at-risk for each condition?\n",
    "# groupby season → mean of each target column (mean of 0/1 = proportion)\n",
    "season_risk = df.groupby('Season')[targets].mean().mul(100).round(1)\n",
    "\n",
    "print('% of days at risk per season:')\n",
    "print(season_risk)\n",
    "print()\n",
    "\n",
    "# plot it\n",
    "season_order = ['Winter', 'Summer', 'Monsoon', 'PostMonsoon']\n",
    "season_risk  = season_risk.reindex(season_order)  # fix the order on x-axis\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 5))  #subplot(1,1)\n",
    "\n",
    "x     = np.arange(len(season_risk))  # [0, 1, 2, 3]\n",
    "width = 0.25\n",
    "\n",
    "for i, target in enumerate(targets):\n",
    "    ax.bar(x + i * width,\n",
    "           season_risk[target],\n",
    "           width,\n",
    "           label=target,\n",
    "           color=colors[target],\n",
    "           alpha=0.85)\n",
    "\n",
    "ax.set_xticks(x + width)\n",
    "ax.set_xticklabels(season_order)\n",
    "ax.set_ylabel('% of days at risk')\n",
    "ax.set_title('Which season is worst for each condition?', fontweight='bold')\n",
    "ax.legend()\n",
    "ax.spines['top'].set_visible(False)\n",
    "ax.spines['right'].set_visible(False)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
