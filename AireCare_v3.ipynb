   "metadata": {},
   "source": [
    "---\n",
    "## Step 1 — Build the Dataset\n",
    "\n",
    "We simulate **2 years of daily weather** (730 days) for central India.\n",
    "\n",
    "**Seasons used:**\n",
    "| Months | Season | Temp Range |\n",
    "|---|---|---|\n",
    "| Nov, Dec, Jan, Feb | Winter | 8°C – 22°C |\n",
    "| Mar, Apr, May | Summer | 28°C – 42°C |\n",
    "| Jun, Jul, Aug, Sep | Monsoon | 24°C – 34°C |\n",
    "| Oct | Post-Monsoon | 20°C – 32°C |\n",
    "\n",
    "Each row = one day. No personal data — just weather."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "fb278c56",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Days per season:\n",
      "  Monsoon: 240 days\n",
      "  PostMonsoon: 60 days\n",
      "  Summer: 180 days\n",
      "  Winter: 250 days\n"
     ]
    }
   ],
   "source": [
    "n_days = 730  # 2 years\n",
    "\n",
    "# ── Month for each day ────────────────────────────────────────────────────────\n",
    "# day 1-30 = month 1, day 31-60 = month 2 ... wraps around for year 2\n",
    "day_of_year = np.arange(1, n_days + 1)\n",
    "month       = ((day_of_year - 1) // 30 % 12) + 1\n",
    "# result: [1,1,1...2,2,2...12,12,12,1,1,1...] cycling through 2 years\n",
    "\n",
    "# ── Season label for each day ─────────────────────────────────────────────────\n",
    "# np.isin checks if each value in 'month' is in the given list\n",
    "season = np.where(np.isin(month, [11, 12, 1, 2]), 'Winter',\n",
    "         np.where(np.isin(month, [3, 4, 5]),       'Summer',\n",
    "         np.where(np.isin(month, [6, 7, 8, 9]),    'Monsoon',\n",
    "                                                    'PostMonsoon')))\n",
    "\n",
    "print('Days per season:')\n",
    "unique, counts = np.unique(season, return_counts=True)\n",
    "for s, c in zip(unique, counts):\n",
    "    print(f'  {s}: {c} days')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "d3689630",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Sample temp_max values: [20.2 17.5 20.9 19.6 14.8]\n",
      "Sample temp_min values: [14.   6.1  7.3 11.4  6.5]\n",
      "Sample temp_range     : [ 6.2 11.5 13.6  8.2  8.3]\n"
     ]
    }
   ],
   "source": [
    "# ── Temperature (Max and Min) ─────────────────────────────────────────────────\n",
    "# We pick a random temp from the realistic range for each season\n",
    "# rng.uniform(low, high, size) = random decimal numbers between low and high\n",
    "#we're generating 730 numbers for each season, but only the relevant ones get used. \n",
    "#It's a bit wasteful but it's the simplest way to write it without loops.\n",
    "\n",
    "temp_max = np.where(season == 'Winter',     rng.uniform(14, 22, n_days),\n",
    "           np.where(season == 'Summer',     rng.uniform(32, 42, n_days),\n",
    "           np.where(season == 'Monsoon',    rng.uniform(28, 36, n_days),\n",
    "                                            rng.uniform(24, 32, n_days))))  # PostMonsoon\n",
    "\n",
    "temp_min = np.where(season == 'Winter',     rng.uniform(6,  14, n_days),\n",
    "           np.where(season == 'Summer',     rng.uniform(22, 28, n_days),\n",
    "           np.where(season == 'Monsoon',    rng.uniform(22, 27, n_days),\n",
    "                                            rng.uniform(16, 22, n_days))))  # PostMonsoon\n",
    "\n",
    "# TempRange = how much the temperature swung in one day\n",
    "# a big swing (e.g. 14C gap) is itself a health trigger\n",
    "temp_range = temp_max - temp_min\n",
    "\n",
    "#[:5]: This is slicing syntax. It tells Python to select only the first 5 elements (indices 0, 1, 2, 3, and 4) of the temp_max data.\n",
    "#.round(1): This method rounds the selected numerical values to one decimal place\n",
    "print('Sample temp_max values:', temp_max[:5].round(1))\n",
    "print('Sample temp_min values:', temp_min[:5].round(1))\n",
    "print('Sample temp_range     :', temp_range[:5].round(1))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "90621ae7",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Weather columns generated ✅\n"
     ]
    }
   ],
   "source": [
    "# ── Humidity ──────────────────────────────────────────────────────────────────\n",
    "# monsoon = very humid, winter = dry, summer = moderate-dry\n",
    "\n",
    "humidity = np.where(season == 'Monsoon',     rng.uniform(70, 95, n_days),\n",
    "           np.where(season == 'Winter',      rng.uniform(25, 55, n_days),\n",
    "           np.where(season == 'Summer',      rng.uniform(20, 45, n_days),\n",
    "                                             rng.uniform(45, 70, n_days))))  # PostMonsoon\n",
    "\n",
    "# ── Barometric Pressure ───────────────────────────────────────────────────────\n",
    "# atmospheric pressure in India hovers around 1010 hPa\n",
    "# rng.normal(mean, std_deviation, size)\n",
    "# std=6 means most days vary within ±6 of the mean\n",
    "pressure = (1010 + rng.normal(0, 6, n_days)).clip(990, 1030)\n",
    "\n",
    "# pressure CHANGE = today's pressure minus yesterday's\n",
    "# np.diff subtracts each value from the next: [1010,1003,1008] → [-7, +5]\n",
    "# we add 0 at the start because day 1 has no \"yesterday\"\n",
    "pressure_change = np.concatenate([[0], np.diff(pressure)])\n",
    "\n",
    "# ── Wind Speed ────────────────────────────────────────────────────────────────\n",
    "wind_speed = np.where(season == 'Monsoon',  rng.uniform(15, 40, n_days),\n",
    "             np.where(season == 'Summer',   rng.uniform(10, 25, n_days),\n",
    "                                            rng.uniform(5,  15, n_days)))\n",
    "\n",
    "# ── AQI (Air Quality Index) ───────────────────────────────────────────────────\n",
    "# India's AQI is worst in winter (crop burning, heating, less wind)\n",
    "# and relatively better in monsoon (rain cleans the air)\n",
    "aqi = np.where(season == 'Winter',    rng.uniform(150, 350, n_days),\n",
    "      np.where(season == 'Summer',    rng.uniform(80,  180, n_days),\n",
    "      np.where(season == 'Monsoon',   rng.uniform(40,  100, n_days),\n",
    "                                      rng.uniform(80,  160, n_days))))  # PostMonsoon\n",
    "\n",
    "# ── Pollen Count ─────────────────────────────────────────────────────────────\n",
    "# highest in spring/summer, low in monsoon (rain washes pollen away)\n",
    "pollen = np.where(season == 'Summer',      rng.uniform(60, 200, n_days),\n",
    "         np.where(season == 'PostMonsoon', rng.uniform(30,  80, n_days),\n",
    "         np.where(season == 'Winter',      rng.uniform(10,  50, n_days),\n",
    "                                           rng.uniform(5,   20, n_days))))  # Monsoon\n",
    "\n",
    "# ── UV Index ─────────────────────────────────────────────────────────────────\n",
    "uv = np.where(season == 'Summer',      rng.uniform(8, 12, n_days),\n",
    "     np.where(season == 'Monsoon',     rng.uniform(4,  8, n_days),\n",
    "     np.where(season == 'PostMonsoon', rng.uniform(5,  9, n_days),\n",
    "                                       rng.uniform(3,  6, n_days))))  # Winter\n",
    "\n",
    "print('Weather columns generated ✅')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "ea82da80",
   "metadata": {},
   "outputs": [
