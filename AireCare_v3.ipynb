     "text": [
      "Labels created:\n",
      "  Migraine  at-risk days: 121  out of 730  (16.6%)\n",
      "  Allergy   at-risk days: 273  out of 730  (37.4%)\n",
      "  JointPain at-risk days: 253  out of 730  (34.7%)\n"
     ]
    }
   ],
   "source": [
    "# ── Health Labels ─────────────────────────────────────────────────────────────\n",
    "# This is the most important part — creating our targets (what we want to predict)\n",
    "#\n",
    "# We use known medical triggers for each condition.\n",
    "# Each trigger is True/False → .astype(float) converts to 1.0/0.0\n",
    "# We multiply each trigger by a weight (how important that trigger is)\n",
    "# Add them all up → if total score > threshold → label it as at-risk (1)\n",
    "#\n",
    "# No single trigger alone crosses the threshold\n",
    "# You need 2+ things going wrong at the same time — more realistic\n",
    "\n",
    "\n",
    "# MIGRAINE TRIGGERS:\n",
    "# hot + humid together, OR cold + dry, OR big pressure drop, OR high UV\n",
    "#The weights decide how much each trigger contributes to the final risk score.\n",
    "migraine_score = (\n",
    "    0.30 * ((temp_max > 35) & (humidity > 65)).astype(float) +   # hot AND humid\n",
    "    0.25 * ((temp_min < 10) & (humidity < 40)).astype(float) +   # cold AND dry\n",
    "    0.25 * (np.abs(pressure_change) > 6).astype(float) +         # pressure swing\n",
    "    0.10 * (uv > 9).astype(float) +                              # very high UV\n",
    "    0.10 * (temp_range > 15).astype(float) +                     # big daily swing\n",
    "    rng.uniform(0, 0.08, n_days)                                  # small random noise\n",
    ")\n",
    "# if score crosses 0.35 → migraine risk day\n",
    "migraine = (migraine_score > 0.35).astype(int)\n",
    "\n",
    "\n",
    "# ALLERGY TRIGGERS:\n",
    "# bad air quality, high pollen, windy, summer season\n",
    "allergy_score = (\n",
    "    0.30 * (aqi > 150).astype(float) +                            # unhealthy AQI\n",
    "    0.30 * (pollen > 80).astype(float) +                          # high pollen\n",
    "    0.20 * (season == 'Summer').astype(float) +                   # summer season\n",
    "    0.10 * (wind_speed > 20).astype(float) +                      # wind spreads pollen\n",
    "    0.10 * (humidity > 75).astype(float) +                        # humid = more particles\n",
    "    rng.uniform(0, 0.08, n_days)\n",
    ")\n",
    "allergy = (allergy_score > 0.35).astype(int)\n",
    "\n",
    "\n",
    "# JOINT PAIN TRIGGERS:\n",
    "# cold nights, damp, pressure drops\n",
    "joint_score = (\n",
    "    0.35 * (temp_min < 12).astype(float) +                        # cold night\n",
    "    0.25 * (humidity > 75).astype(float) +                        # damp air\n",
    "    0.25 * (pressure_change < -5).astype(float) +                 # pressure dropping\n",
    "    0.15 * (temp_range > 14).astype(float) +                      # big daily swing\n",
    "    rng.uniform(0, 0.08, n_days)\n",
    ")\n",
    "joint_pain = (joint_score > 0.35).astype(int)\n",
    "\n",
    "\n",
    "print('Labels created:')\n",
    "print(f'  Migraine  at-risk days: {migraine.sum()}  out of {n_days}  ({migraine.mean()*100:.1f}%)')\n",
    "print(f'  Allergy   at-risk days: {allergy.sum()}  out of {n_days}  ({allergy.mean()*100:.1f}%)')\n",
    "print(f'  JointPain at-risk days: {joint_pain.sum()}  out of {n_days}  ({joint_pain.mean()*100:.1f}%)')"
   ]
  },
