   "source": [
    "def train_condition(target_name):\n",
    "    \"\"\"\n",
    "    Train KNN, RF, GBM for one health condition.\n",
    "    Returns the results for all 3 models + the best one.\n",
    "    \"\"\"\n",
    "\n",
    "    print(f'\\n--- {target_name} ---')\n",
    "\n",
    "    X = df_model[FEATURES]\n",
    "    y = df_model[target_name]\n",
    "\n",
    "    # Step 1: split — 80% train, 20% test\n",
    "    # stratify=y keeps the same at-risk ratio in both splits\n",
    "    X_train, X_test, y_train, y_test = train_test_split(\n",
    "        X, y, test_size=0.2, random_state=SEED, stratify=y\n",
    "    )\n",
    "    print(f'Train: {len(X_train)} days | Test: {len(X_test)} days')\n",
    "\n",
    "    # Step 2: scale features\n",
    "    # StandardScaler makes all features the same scale\n",
    "    # e.g. AQI goes up to 350, humidity is 0-100 — without scaling AQI dominates\n",
    "    # fit ONLY on training data, then apply the same transform to test\n",
    "    scaler     = StandardScaler()\n",
    "    X_train_sc = scaler.fit_transform(X_train)\n",
    "    X_test_sc  = scaler.transform(X_test)\n",
    "\n",
    "    # Step 3: SMOTE\n",
    "    # if only 20% of days are at-risk, the model learns to just say\n",
    "    # \"no risk\" every day and gets 80% accuracy — but catches nothing!\n",
    "    # SMOTE creates extra synthetic at-risk days so the classes are balanced\n",
    "    # ONLY on training data — test stays real\n",
    "    smote            = SMOTE(random_state=SEED, k_neighbors=5)\n",
    "    X_res, y_res     = smote.fit_resample(X_train_sc, y_train)\n",
    "    print(f'After SMOTE: {dict(pd.Series(y_res).value_counts().sort_index())}')\n",
    "\n",
    "    # Step 4: train each model with GridSearchCV\n",
    "    results = {}\n",
    "    for name, cfg in model_configs.items():\n",
    "        print(f'  Training {name}...', end=' ')\n",
    "        grid = GridSearchCV(\n",
    "            cfg['model'], cfg['params'],\n",
    "            scoring='roc_auc', cv=cv,\n",
    "            n_jobs=-1, verbose=0\n",
    "        )\n",
    "        grid.fit(X_res, y_res)\n",
    "\n",
    "        best   = grid.best_estimator_\n",
    "        y_pred = best.predict(X_test_sc)\n",
    "        y_prob = best.predict_proba(X_test_sc)[:, 1]\n",
    "\n",
    "        results[name] = {\n",
    "            'model'    : best,\n",
    "            'cv_auc'   : grid.best_score_,\n",
    "            'test_auc' : roc_auc_score(y_test, y_prob),\n",
    "            'y_pred'   : y_pred,\n",
    "            'y_prob'   : y_prob\n",
    "        }\n",
    "        print(f'AUC = {results[name][\"test_auc\"]:.3f}')\n",
    "\n",
    "    # Step 5: pick best model\n",
    "    best_name = max(results, key=lambda k: results[k]['test_auc'])\n",
    "    print(f'  Best: {best_name}')\n",
    "\n",
    "    return {\n",
    "        'scaler'    : scaler,\n",
    "        'models'    : results,\n",
    "        'best'      : best_name,\n",
    "        'y_test'    : y_test,\n",
    "        'X_test_sc' : X_test_sc\n",
    "    }\n",
    "\n",
    "\n",
    "# train all 3 conditions\n",
    "all_results = {}\n",
    "for target in ['Migraine', 'Allergy', 'JointPain']:\n",
    "    all_results[target] = train_condition(target)\n",
    "\n",
    "print('\\n🎉 All done!')"
   ]
  },
