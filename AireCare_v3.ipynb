      "  Pressure_hPa\n",
      "  PressureChange_hPa\n",
      "  WindSpeed_kmh\n",
      "  AQI\n",
      "  PollenCount\n",
      "  UV_Index\n",
      "  HeatIndex\n",
      "  ColdDampScore\n",
      "  AbsPressureChange\n",
      "  Season_PostMonsoon\n",
      "  Season_Summer\n",
      "  Season_Winter\n"
     ]
    }
   ],
   "source": [
    "df_model = df.copy()  # work on a copy, never touch the original\n",
    "\n",
    "# HeatIndex = \"feels like\" temperature\n",
    "# hot temp + high humidity feels even hotter — known migraine trigger\n",
    "df_model['HeatIndex'] = (df_model['TempMax_C']\n",
    "                         + 0.33 * df_model['Humidity_pct']\n",
    "                         - 0.70 * df_model['WindSpeed_kmh']\n",
    "                         - 4.0).round(1)   #actual heat index formula\n",
    "\n",
    "# ColdDampScore = cold + wet combined\n",
    "# both together are worse for joint pain than either alone\n",
    "df_model['ColdDampScore'] = (\n",
    "    (10 - df_model['TempMin_C'].clip(upper=10)) *\n",
    "    (df_model['Humidity_pct'] / 100)\n",
    ").clip(lower=0).round(2)\n",
    "\n",
    "# AbsPressureChange = size of the pressure swing, ignoring direction\n",
    "# both drops AND rises can trigger migraines\n",
    "df_model['AbsPressureChange'] = df_model['PressureChange_hPa'].abs()\n",
    "\n",
    "# Season → numbers (models need numbers, not text)\n",
    "# pd.get_dummies makes one column per season: Season_Summer, Season_Monsoon etc\n",
    "# drop_first=True drops one (Monsoon becomes the \"default\" — no column needed) as monsoon is first alphabetically \n",
    "#when all three are 0, it must be winter. \n",
    "#This avoids a math problem called multicollinearity where one column is perfectly predictable from the others.\n",
    "df_model = pd.get_dummies(df_model, columns=['Season'], drop_first=True)\n",
    "\n",
    "# define which columns are inputs (features) and which are outputs (targets)\n",
    "FEATURES = [c for c in df_model.columns\n",
    "            if c not in ['Month', 'Migraine', 'Allergy', 'JointPain']]\n",
    "\n",
    "print(f'Features ({len(FEATURES)} total):')\n",
    "for f in FEATURES:\n",
    "    print(f'  {f}')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "85b40e43",
   "metadata": {},
   "source": [
    "---\n",
    "## Step 5 — Train Models\n",
    "\n",
    "For each condition (Migraine, Allergy, JointPain) we:\n",
    "1. Split data into train (80%) and test (20%)\n",
    "2. Scale the features with StandardScaler\n",
    "3. Fix class imbalance with SMOTE\n",
    "4. Try KNN, Random Forest, GBM — pick the best one"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "21938fd0",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Configs ready ✅\n"
     ]
    }
   ],
   "source": [
    "# hyperparameter grids for each model\n",
    "# GridSearchCV will try every combination and pick the best\n",
    "model_configs = {\n",
    "    'KNN': {\n",
    "        'model' : KNeighborsClassifier(),\n",
    "        'params': {\n",
    "            'n_neighbors': [5, 11, 21],      # how many nearby days to look at\n",
    "            'weights'    : ['uniform', 'distance']\n",
    "        }\n",
    "    },\n",
    "    'RandomForest': {\n",
    "        'model' : RandomForestClassifier(random_state=SEED, n_jobs=-1),\n",
    "        'params': {\n",
    "            'n_estimators'    : [100, 200],  # number of trees\n",
    "            'max_depth'       : [5, 10, None],\n",
    "            'min_samples_split': [2, 5]\n",
    "        }\n",
    "    },\n",
    "    'GBM': {\n",
    "        'model' : GradientBoostingClassifier(random_state=SEED),\n",
    "        'params': {\n",
    "            'n_estimators' : [100, 200],\n",
    "            'learning_rate': [0.05, 0.1],\n",
    "            'max_depth'    : [3, 5]\n",
    "        }\n",
    "    }\n",
    "}\n",
    "\n",
    "cv = StratifiedKFold(n_splits=5, shuffle=True, random_state=SEED)\n",
    "print('Configs ready ✅')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 14,
   "id": "6a21b194",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
