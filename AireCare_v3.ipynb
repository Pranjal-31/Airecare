     "output_type": "display_data"
    }
   ],
   "source": [
    "# correlation = how much two things move together\n",
    "# +1 = when one goes up the other goes up too\n",
    "# -1 = when one goes up the other goes down\n",
    "#  0 = no relationship\n",
    "\n",
    "# we only want numeric columns (Season is text so we drop it)\n",
    "numeric_df = df.drop(columns=['Season', 'Month'])\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(11, 8))\n",
    "sns.heatmap(\n",
    "    numeric_df.corr(),\n",
    "    annot=True,       # show the numbers inside each box\n",
    "    fmt='.2f',        # 2 decimal places\n",
    "    cmap='RdBu_r',    # red = positive, blue = negative\n",
    "    center=0,\n",
    "    linewidths=0.4,\n",
    "    annot_kws={'size': 8},\n",
    "    ax=ax\n",
    ")\n",
    "ax.set_title('Correlation — look at the last 3 rows for what drives each condition',\n",
    "             fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
